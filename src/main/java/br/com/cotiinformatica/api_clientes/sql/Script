-- Script para criar uma tabela de clientes no PostgreSQL
CREATE TABLE clientes (
    id          UUID                PRIMARY KEY,
    nome        VARCHAR(100)        NOT NULL,
    email       VARCHAR(50)         NOT NULL,
    cpf         CHAR(11)            NOT NULL
);

